diff --git a/src/components/code-editor/view/subcomponents/OfficePreview.tsx b/src/components/code-editor/view/subcomponents/OfficePreview.tsx
new file mode 100644
index 0000000..3aecc41
--- /dev/null
+++ b/src/components/code-editor/view/subcomponents/OfficePreview.tsx
@@ -0,0 +1,61 @@
+// AgentMate office preview bridge — renders docx/xlsx/pptx (and the wider office
+// family) inline via @open-file-viewer. This module is loaded through React.lazy()
+// from CodeEditorMediaPreview, so the heavy office dependencies (docx-preview,
+// mammoth, xlsx, @aiden0z/pptx-renderer, jszip, dompurify, ...) are code-split
+// into an async chunk that is fetched only the first time a user opens an office
+// file. Existing text/image/pdf/audio/video handling is untouched.
+// AGENTMATE_OFFICE_PREVIEW_BRIDGE
+import { useMemo, useState } from 'react';
+import { FileViewer } from '@open-file-viewer/react';
+import { officePlugin } from '@open-file-viewer/core';
+import '@open-file-viewer/core/style.css';
+
+type OfficePreviewProps = {
+  // Same-origin blob URL of the office file bytes — built by CodeEditorMediaPreview
+  // from the authenticated /api/projects/:id/files/content response.
+  url: string;
+  // File name; officePlugin dispatches docx/xlsx/pptx/etc. by its extension.
+  fileName: string;
+  errorLabel: string;
+};
+
+function detectLocale(): 'zh-CN' | 'en-US' {
+  if (typeof navigator !== 'undefined' && navigator.language?.toLowerCase().startsWith('zh')) {
+    return 'zh-CN';
+  }
+  return 'en-US';
+}
+
+export default function OfficePreview({ url, fileName, errorLabel }: OfficePreviewProps) {
+  // officePlugin() returns a new plugin instance per call. Memoize so FileViewer's
+  // mount effect does not tear down and rebuild the viewer on every parent render.
+  const plugins = useMemo(() => [officePlugin()], []);
+  const locale = useMemo(detectLocale, []);
+  const [failed, setFailed] = useState(false);
+
+  if (failed) {
+    return (
+      <div className="flex h-full w-full flex-col items-center justify-center gap-1 p-8 text-center text-muted-foreground">
+        <p className="text-sm">{errorLabel}</p>
+        <p className="break-all text-xs">{fileName}</p>
+      </div>
+    );
+  }
+
+  return (
+    <div className="h-full w-full" data-agentmate-office-preview="">
+      <FileViewer
+        file={url}
+        fileName={fileName}
+        plugins={plugins}
+        locale={locale}
+        theme="auto"
+        toolbar
+        width="100%"
+        height="100%"
+        onError={() => setFailed(true)}
+        onUnsupported={() => setFailed(true)}
+      />
+    </div>
+  );
+}
